# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/wedding_face_match

# Storage paths (relative to project root)
UPLOADS_DIR=uploads
SELFIES_DIR=selfies
MODELS_DIR=models
DATA_DIR=data

# HNSW tuning
HNSW_DIM=128
HNSW_MAX_ELEMENTS=50000
HNSW_EF_CONSTRUCTION=200
HNSW_M=16
HNSW_EF_SEARCH=100

# Matching — face-api descriptors live in roughly [0, 1.4] L2 space.
# Distance maps to similarity via:  similarity = 1 - distance / 1.4
# Defaults below filter "strictly ABOVE" the named percent on the rounded
# badge — pick the row whose match-percent you want to keep.
#   0.273 → above 80% (default; only matches that display as 81% or higher)
#   0.413 → above 70%
#   0.553 → above 60% (catches more, some false positives)
#   0.693 → above 50% (very permissive; mostly noise)
MATCH_DISTANCE_THRESHOLD=0.273
MATCH_TOP_K=20

# Default event id to tag images with (camera simulation)
DEFAULT_EVENT_ID=default-event

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
